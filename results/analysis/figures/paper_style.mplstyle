figure.dpi: 110
savefig.dpi: 200
savefig.bbox: tight
font.size: 11.5
font.family: DejaVu Sans
axes.titlesize: 13
axes.titleweight: bold
axes.labelsize: 11.5
legend.fontsize: 10
legend.frameon: False
xtick.labelsize: 10.5
ytick.labelsize: 10.5
axes.spines.top: False
axes.spines.right: False
axes.grid: True
axes.axisbelow: True
grid.alpha: 0.22
grid.linewidth: 0.8
lines.linewidth: 2.0
lines.markersize: 7
